# Box OAuth 2.0 credentials (replace placeholders with real values)
BOX_CLIENT_ID=your_client_id_here
BOX_CLIENT_SECRET=your_client_secret_here

# Must exactly match the Redirect URI configured in your Box app settings
BOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# Optional default export path; the app also prompts a Save As dialog
BOX_EXPORT_XLSX=/tmp/box_export.xlsx
